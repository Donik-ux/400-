# ── Groq (AI trip plans, price commentary) ─────────────────────────────
# Get a free key at https://console.groq.com/keys — no card required.
# SERVER-side only — NO VITE_ prefix. Vite bundles anything prefixed VITE_
# straight into the public JS, so a VITE_ key is readable by any visitor via
# devtools. This one is only ever read by api/aiAsk.js.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Public feature flag (not a secret) — set true once GROQ_API_KEY is
# configured, so the client knows it's safe to attempt AI calls.
VITE_AI_ENABLED=false

# ── Amadeus Self-Service API (real flight + hotel data via GDS) ────────
# Sign up FREE at https://developers.amadeus.com/  →  Create app  →  copy keys.
# Free tier: 2000 flight searches/month, real prices from Skyscanner-grade data.
# The SAME two keys also power api/hotels.js (Hotel Search v3) — no separate
# signup needed for real hotel prices on TourDetail.jsx.
# These are SERVER-side keys — NO VITE_ prefix.  Set them in Vercel project
# settings → Environment Variables (or in this .env for local dev).
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Set to "production" only after upgrading to a paid Amadeus production app.
AMADEUS_ENV=test

# ── Travelpayouts / Aviasales (real prices, ANY route, free) ───────────
TRAVELPAYOUTS_TOKEN=
TRAVELPAYOUTS_MARKER=

# ── Duffel (real flight offers, free self-serve test mode) ─────────────
# Sign up FREE at https://app.duffel.com/join — a `duffel_test_...` API key is
# issued instantly, no approval/business-review step. Test keys return
# realistic offers from Duffel's sandbox airlines (not live inventory), which
# is enough for real comparative pricing. SERVER-side only — NO VITE_ prefix.
DUFFEL_API_KEY=

# ── WhatsApp lead-gen (Services page CTAs + floating button) ───────────
# Real WhatsApp Business number, digits only, full international format,
# no "+", spaces or dashes (e.g. Uzbekistan: 998901234567). Public — this is
# meant to be visible in the client bundle, same as any wa.me link. Leave
# unset and the WhatsApp CTAs hide themselves (fall back to email) rather
# than linking a dead number.
VITE_WHATSAPP_NUMBER=

# ── Admin login (src/pages/admin), verified server-side by api/adminAuth.js ──
# Pick a real password — this used to be hardcoded in the client bundle.
ADMIN_PASSWORD=
# Random signing secret for admin session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Do not reuse across environments; do not commit the real value.
ADMIN_TOKEN_SECRET=
